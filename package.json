{
	"name": "rust-todo-app",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "npm run tw:build && cargo leptos build --release",
		"check": "cargo check --features ssr --bin rust-todo-app && cargo check --features hydrate --lib",
		"dev": "npm run tw:build && concurrently -k -n tailwind,leptos \"npm:tw:watch\" \"cargo leptos watch\"",
		"dev:server": "npm run dev",
		"serve": "npm run dev",
		"tw:build": "npx @tailwindcss/cli -i ./src/tailwind.css -o ./style.css",
		"tw:watch": "npx @tailwindcss/cli -i ./src/tailwind.css -o ./style.css --watch",
		"prepare": "husky"
	},
	"dependencies": {
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.1",
		"@commitlint/config-conventional": "^20.4.1",
		"@commitlint/types": "^20.4.0",
		"@tailwindcss/cli": "^4.2.4",
		"concurrently": "^9.2.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"tailwindcss": "^4.2.4"
	}
}
